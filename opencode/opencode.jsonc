{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.local/share/neobean": "allow",
      "~/.local/share/neobean/**": "allow",
      "/opt/homebrew/share/nvim": "allow",
      "/opt/homebrew/share/nvim/**": "allow",
      "/opt/homebrew/Cellar/neovim": "allow",
      "/opt/homebrew/Cellar/neovim/**": "allow"
    }
  }
}
